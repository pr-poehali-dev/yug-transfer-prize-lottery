{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Service alive",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Create request without route rejected",
      "method": "POST",
      "path": "/?action=create_request",
      "body": {"phone": "+79991234567"},
      "expectedStatus": 400
    },
    {
      "name": "Register bad phone rejected",
      "method": "POST",
      "path": "/?action=register",
      "body": {"phone": "123", "password": "1234"},
      "expectedStatus": 400
    },
    {
      "name": "Login without password rejected",
      "method": "POST",
      "path": "/?action=login",
      "body": {"phone": "+79991234567"},
      "expectedStatus": 400
    }
  ]
}